# Google スプレッドシートID (URLの /d/<ここ>/edit 部分)
SPREADSHEET_ID=your_spreadsheet_id_here

# GCP サービスアカウントキーファイルのパス
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# スクレイピング設定
# Playwrightをヘッドレスモードで実行するか (true=バックグラウンド実行, false=ブラウザを表示)
HEADLESS=true

# リクエスト間の待機時間 (ミリ秒, ランダム幅)
SCRAPE_DELAY_MIN_MS=1000
SCRAPE_DELAY_MAX_MS=3000
